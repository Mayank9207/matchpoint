# Google OAuth 2.0 Web client ID.
# MUST be identical to GOOGLE_CLIENT_ID in engine/backend/.env
# (frontend mints the ID token for this audience; backend verifies against it).
VITE_GOOGLE_CLIENT_ID=

# Google Maps JS SDK key (geocoding + location search).
VITE_GOOGLE_MAPS_API_KEY=

# Backend API base URL. Omit in dev — defaults to http://localhost:8000.
# Set this only for production builds (e.g. https://your-api.com).
# VITE_API_URL=
